<div class="logo-ciclico">
  <img src="/logos/logo1.png"  alt="" />
  <img src="/logos/logo2.png"  alt="" />
  <img src="/logos/logo3.png"  alt="" />
  <img src="/logos/logo4.png"  alt="" />
  <img src="/logos/logo5.png"  alt="" />
  <img src="/logos/logo6.png"  alt="" />
  <img src="/logos/logo7.png"  alt="" />
  <img src="/logos/logo8.png"  alt="" />
  <img src="/logos/logo9.png"  alt="" />
  <img src="/logos/logo10.png" alt="" />
</div>

<style>
  .logo-ciclico {
    position: relative;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
  }

  .logo-ciclico img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    border-radius: 4px;
    animation: logo-ciclo 40s infinite;
  }

  .logo-ciclico img:nth-child(1)  { animation-delay:  0s; }
  .logo-ciclico img:nth-child(2)  { animation-delay:  4s; }
  .logo-ciclico img:nth-child(3)  { animation-delay:  8s; }
  .logo-ciclico img:nth-child(4)  { animation-delay: 12s; }
  .logo-ciclico img:nth-child(5)  { animation-delay: 16s; }
  .logo-ciclico img:nth-child(6)  { animation-delay: 20s; }
  .logo-ciclico img:nth-child(7)  { animation-delay: 24s; }
  .logo-ciclico img:nth-child(8)  { animation-delay: 28s; }
  .logo-ciclico img:nth-child(9)  { animation-delay: 32s; }
  .logo-ciclico img:nth-child(10) { animation-delay: 36s; }

  @keyframes logo-ciclo {
    0%    { opacity: 0; }
    2.5%  { opacity: 1; }
    10%   { opacity: 1; }
    12.5% { opacity: 0; }
    100%  { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-ciclico img { animation: none; }
    .logo-ciclico img:nth-child(1) { opacity: 1; }
  }
</style>
