---
import LogoCiclico from './LogoCiclico.astro';
---

<footer class="lo-footer">
  <div class="lo-footer-inner">

    <a href="https://lopublico.es" class="lo-footer-marca" id="logo-footer" target="_blank" rel="noopener">
      <LogoCiclico />
      <div class="lo-footer-marca-texto">
        <span class="lo-footer-nombre">Lo público<span class="lo-footer-punto">.</span></span>
        <span class="lo-footer-lema">La administración en datos</span>
      </div>
    </a>

    <div class="lo-footer-centro">
      Datos: <a href="https://contrataciondelsectorpublico.gob.es" class="lo-footer-enlace" target="_blank" rel="noopener">PLACSP</a>
      · Actualizado junio 2026
    </div>

    <div class="lo-footer-derecha">
      <span>© 2026 · Por <a href="https://avelrom.es" class="lo-footer-enlace" target="_blank" rel="noopener">avelrom</a></span>
      <a href="https://creativecommons.org/licenses/by/4.0/deed.es" class="lo-footer-licencia" target="_blank" rel="noopener license" title="Licencia Creative Commons Atribución 4.0 Internacional">
        CC BY 4.0
      </a>
    </div>

  </div>
</footer>

<style>
  .lo-footer {
    border-top: 1px solid var(--color-borde);
  }

  .lo-footer-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 24px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .lo-footer-marca {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .lo-footer-marca-texto {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 44px;
    padding-left: 12px;
    border-left: 1px solid #d4d4d4;
  }

  .lo-footer-nombre {
    font-family: 'Geist', sans-serif;
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-texto);
  }

  .lo-footer-punto { color: var(--color-texto); }

  .lo-footer-lema {
    font-family: 'Lora', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    line-height: 1;
    color: #6f6f6f;
  }

  .lo-footer-centro {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: #a1a1aa;
  }

  .lo-footer-derecha {
    display: flex;
    align-items: center;
    gap: 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: #a1a1aa;
  }

  .lo-footer-enlace {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }

  .lo-footer-licencia {
    color: inherit;
    text-decoration: none;
    opacity: 0.75;
  }

  .lo-footer-licencia:hover { opacity: 1; }

  @media (max-width: 768px) {
    .lo-footer-inner { padding: 20px; }
  }
</style>
