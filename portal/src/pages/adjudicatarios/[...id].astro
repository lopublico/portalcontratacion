---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PerfilEntidad from '../../components/PerfilEntidad';

const { id } = Astro.params;
if (!id) return Astro.redirect('/adjudicatarios');
const decodedId = decodeURIComponent(id);
---

<Layout titulo="Adjudicatario">
  <div style="margin-bottom: 0.75rem;">
    <a href="/adjudicatarios" style="font-size: var(--texto-sm); color: var(--color-texto-suave); text-decoration: none;">
      ← Adjudicatarios
    </a>
  </div>
  <PerfilEntidad client:load tipo="adjudicatario" id={decodedId} />
</Layout>
